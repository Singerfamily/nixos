{
  "nixEnvSelector.nixFile": "${workspaceFolder}/flake.nix",
  "nix.serverPath": ["nix", "run", "github:nix-community/nixd"], // or "nixd", or ["executable", "argument1", ...]
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        // For flake.
        "expr": "import (builtins.getFlake \"${workspaceFolder}\").inputs.nixpkgs { }"
      },
      // "formatting": {
      //   // Which command you would like to do formatting
      //   "command": ["nixfmt"]
      // },
      // Tell the language server your desired option set, for completion
      // This is lazily evaluated.
      "options": {
        // Map of eval information
        // If this is omitted, default search path (<nixpkgs>) will be used.
        "nixos": {
          // This name "nixos" could be arbitrary.
          // The expression to eval, interpret it as option declarations.
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.\"${env:HOST}\".options"
        },
        // By default there is no home-manager options completion, thus you can add this entry.
        // "home-manager": {
        //   "expr": "(builtins.getFlake \"${workspaceFolder}\").homeConfigurations.\"${env:USERNAME}@${env:HOST}\".options"
        // }
      }
      // Control the diagnostic system
      // "diagnostic": {
      //   "suppress": ["sema-extra-with"]
      // }
    }
  },
  "chat.tools.terminal.autoApprove": {
    "nix": true
  }
}
